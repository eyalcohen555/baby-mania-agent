    "custom_liquid_etUrWn": {
      "type": "custom-liquid",
      "name": "t:sections.custom-liquid.presets.name",
      "settings": {
        "custom_liquid": "<style>\n  .video-carousel{display:flex;flex-direction:column;gap:14px;}\n  .video-row{display:flex;flex-wrap:nowrap;gap:14px;overflow-x:auto;overflow-y:hidden;scroll-snap-type:x mandatory;-webkit-overflow-scrolling:touch;padding:6px 4px;width:100%;}\n  .video-row::-webkit-scrollbar{display:none;}\n  .video-card{flex:0 0 auto;width:280px;height:280px;scroll-snap-align:start;border-radius:16px;overflow:hidden;background:#000;position:relative;cursor:pointer;}\n  .video-card img,.video-card iframe{position:absolute;inset:0;width:100%;height:100%;border:0;object-fit:cover;}\n  .play{position:absolute;inset:0;display:flex;align-items:center;justify-content:center;background:rgba(0,0,0,.18);pointer-events:none;}\n  .play span{width:58px;height:58px;border-radius:50%;background:#fff;display:flex;align-items:center;justify-content:center;font-size:24px;}\n  @media (max-width: 749px){.video-card{width:60vw;height:60vw;border-radius:18px;}}\n<\/style>\n\n<div class=\"video-carousel\" id=\"carousel-{{ section.id }}\">\n\n  <div class=\"video-row\">\n    {% assign row1 = \"1150827345,1150828535,1150843187\" | split: \",\" %}\n    {% for id in row1 %}\n      <div class=\"video-card\" data-vimeo=\"{{ id }}\">\n        <img src=\"https:\/\/vumbnail.com\/{{ id }}.jpg\" loading=\"lazy\" decoding=\"async\">\n        <div class=\"play\"><span>▶<\/span><\/div>\n      <\/div>\n    {% endfor %}\n  <\/div>\n\n  <div style=\"height:220px;\"><\/div>\n\n  <div class=\"video-row\" id=\"row2-mount-{{ section.id }}\"><\/div>\n\n  <template id=\"row2-tpl-{{ section.id }}\">\n    {% assign row2 = \"1150831579,1150844000,1150844816\" | split: \",\" %}\n    {% for id in row2 %}\n      <div class=\"video-card\" data-vimeo=\"{{ id }}\">\n        <img src=\"https:\/\/vumbnail.com\/{{ id }}.jpg\" loading=\"lazy\" decoding=\"async\">\n        <div class=\"play\"><span>▶<\/span><\/div>\n      <\/div>\n    {% endfor %}\n  <\/template>\n\n<\/div>\n\n<script>\n(function(){\n  var root = document.getElementById('carousel-{{ section.id }}');\n  if(!root) return;\n\n  var mount = document.getElementById('row2-mount-{{ section.id }}');\n  var tpl = document.getElementById('row2-tpl-{{ section.id }}');\n  var loadedRow2 = false;\n\n  function loadRow2(){\n    if(loadedRow2 || !mount || !tpl) return;\n    loadedRow2 = true;\n    mount.innerHTML = tpl.innerHTML;\n  }\n\n  if(mount && 'IntersectionObserver' in window){\n    var io = new IntersectionObserver(function(entries){\n      entries.forEach(function(e){\n        if(e.isIntersecting){\n          loadRow2();\n          io.disconnect();\n        }\n      });\n    }, { rootMargin: '-300px 0px' });\n    io.observe(mount);\n  } else {\n    loadRow2();\n  }\n\n  root.addEventListener('click', function(ev){\n    var card = ev.target.closest && ev.target.closest('.video-card');\n    if(!card || !root.contains(card)) return;\n    if(card.querySelector('iframe')) return;\n\n    var id = card.getAttribute('data-vimeo');\n    card.innerHTML =\n      '<iframe src=\"https:\/\/player.vimeo.com\/video\/'+id+'?playsinline=1&autoplay=1&muted=1\" '+\n      'allow=\"autoplay; fullscreen; picture-in-picture\" allowfullscreen><\/iframe>';\n  });\n})();\n<\/script>",
        "color_scheme": "",
        "padding_top": 20,
        "padding_bottom": 24
      }

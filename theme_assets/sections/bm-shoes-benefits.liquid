        {
          "type": "shoe_benefit",
          "settings": {
            "icon": "🪶",
            "title": "קלה במיוחד",
            "body": "הילד זז חופשי כל היום — בלי להתעייף ובלי לבקש הפסקות"
          }
        },
        {
          "type": "shoe_benefit",
          "settings": {
            "icon": "🛡️",

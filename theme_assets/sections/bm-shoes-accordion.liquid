          }
        },
        {
          "type": "faq",
          "settings": {
            "question": "כל כמה זמן צריך לבדוק אם הנעל עדיין מתאימה?",
            "answer": "כל חודשיים-שלושה בגיל הפעוט. הרגליים גדלות מהר ונעל קטנה לוחצת על האצבעות בלי שההורה שם לב. אם הילד מתחיל להסיר את הנעליים מיד לאחר הנעילה — כדאי למדוד מחדש."
          }
        },
        {
          "type": "faq",
          "settings": {
            "question": "מתי הזמן הנכון לקנות נעליים ראשונות?",
            "answer": "כשהילד הולך לבד בחוץ. בבית עדיף יחף כמה שיותר — זה מחזק את כף הרגל ומפתח שיווי משקל טבעי. הנעל הראשונה צריכה להיות גמישה, קלה ועם אחיזה — לא נוקשה."
          }
        }
      ]
    }
  ]
}
{% endschema %}

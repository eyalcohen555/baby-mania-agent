{% comment %}
  BabyMania — Store Urgency (Section 7 of 8)
  File: sections/bm-store-urgency.liquid
  Purpose: Urgency block — sold % is JS-random (82–94) per load,
           with optional manual override via section settings.
{% endcomment %}

{% if section.settings.enabled %}

<style>
  /* ============================================================
     BM-URGENCY — Brand Palette Variables
  ============================================================ */
  .bm-urgency-root {
    --bm-urgency-card-from:  #FAF3EC;
    --bm-urgency-card-to:    #FFFDF9;
    --bm-urgency-border:     #D4B99A;
    --bm-urgency-text-dark:  #3D2B1F;
    --bm-urgency-text-mid:   #8B5E3C;
    --bm-urgency-text-soft:  #A07850;
    --bm-urgency-dot:        #C4835E;
    --bm-urgency-bar-track:  #E8DDD3;
    --bm-urgency-bar-from:   #8B5E3C;
    --bm-urgency-bar-to:     #C4956A;
    --bm-urgency-btn-bg:     #8B5E3C;
    --bm-urgency-btn-hover:  #7A5234;
    --bm-urgency-radius:     14px;
    --bm-urgency-font:       'Heebo', sans-serif;
  }

  /* ============================================================
     ANIMATIONS
  ============================================================ */
  @keyframes bm-urgency-pulse {
    0%, 100% { opacity: 1;   transform: scale(1);    }
    50%       { opacity: 0.5; transform: scale(0.82); }
  }

  @keyframes bm-urgency-lightning-fade {
    0%, 100% { opacity: 1; }
    50%       { opacity: 0.4; }
  }

  /* ============================================================
     SECTION WRAPPER
  ============================================================ */
  .bm-urgency-root {
    padding: 20px;
    font-family: var(--bm-urgency-font);
    direction: rtl;
    text-align: right;
  }

  /* ============================================================
     CARD
  ============================================================ */
  .bm-urgency-card {
    position: relative;
    overflow: hidden;
    background: linear-gradient(
      135deg,
      var(--bm-urgency-card-from) 0%,
      var(--bm-urgency-card-to)   100%
    );
    border: 1px solid var(--bm-urgency-border);
    border-radius: var(--bm-urgency-radius);
    box-shadow: 0 2px 12px rgba(139, 94, 60, 0.08);
    padding: 32px 28px;
    max-width: 800px;
    margin: 0 auto;
    opacity: 0;
    transform: translateY(18px);
    transition: opacity 0.5s ease, transform 0.5s ease;
  }

  .bm-urgency-card.bm-urgency--visible {
    opacity: 1;
    transform: translateY(0);
  }

  /* ============================================================
     DECORATIVE CIRCLES
  ============================================================ */
  .bm-urgency-circle {
    position: absolute;
    border-radius: 50%;
    background: rgba(139, 94, 60, 0.04);
    pointer-events: none;
  }

  .bm-urgency-circle--1 {
    width: 220px; height: 220px;
    top: -80px; left: -60px;
  }

  .bm-urgency-circle--2 {
    width: 160px; height: 160px;
    bottom: -50px; right: -40px;
  }

  .bm-urgency-circle--3 {
    width: 90px; height: 90px;
    top: 50%; left: 50%;
    transform: translate(-50%, -50%);
    background: rgba(139, 94, 60, 0.025);
  }

  /* ============================================================
     CONTENT LAYER
  ============================================================ */
  .bm-urgency-content {
    position: relative;
    z-index: 1;
    display: flex;
    flex-direction: column;
    gap: 20px;
  }

  /* ============================================================
     HEADLINE ROW — extra bottom margin for breathing room
  ============================================================ */
  .bm-urgency-headline-row {
    display: flex;
    align-items: center;
    gap: 10px;
    margin-bottom: 8px;
  }

  .bm-urgency-dot {
    width: 10px;
    height: 10px;
    border-radius: 50%;
    background: var(--bm-urgency-dot);
    flex-shrink: 0;
    animation: bm-urgency-pulse 2.2s ease-in-out infinite;
  }

  .bm-urgency-headline {
    font-size: 20px;
    font-weight: 800;
    color: var(--bm-urgency-text-dark);
    margin: 0;
    line-height: 1.3;
    letter-spacing: 0.04em;
  }

  .bm-urgency-lightning {
    font-size: 18px;
    line-height: 1;
    flex-shrink: 0;
    animation: bm-urgency-lightning-fade 3s ease-in-out infinite;
  }

  /* ============================================================
     STOCK ROW (above bar)
  ============================================================ */
  .bm-urgency-stock-row {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 8px;
  }

  .bm-urgency-stock-label {
    font-size: 14px;
    font-weight: 400;
    color: var(--bm-urgency-text-soft);
  }

  .bm-urgency-stock-count {
    font-size: 14px;
    font-weight: 700;
    color: var(--bm-urgency-text-mid);
    white-space: nowrap;
    letter-spacing: -0.01em;
  }

  /* ============================================================
     PROGRESS BAR
  ============================================================ */
  .bm-urgency-bar-wrap {
    display: flex;
    flex-direction: column;
    gap: 8px;
  }

  .bm-urgency-bar-track {
    width: 100%;
    height: 10px;
    background: var(--bm-urgency-bar-track);
    border-radius: 99px;
    overflow: hidden;
  }

  .bm-urgency-bar-fill {
    height: 100%;
    border-radius: 99px;
    background: linear-gradient(
      90deg,
      var(--bm-urgency-bar-from),
      var(--bm-urgency-bar-to)
    );
    width: 0%;
    /* target set by JS via style.setProperty('--bm-urgency-bar-target', ...) */
    transition: width 1.2s cubic-bezier(0.22, 0.61, 0.36, 1);
  }

  .bm-urgency-card.bm-urgency--visible .bm-urgency-bar-fill {
    width: var(--bm-urgency-bar-target, 0%);
  }

  .bm-urgency-bar-meta {
    display: flex;
    justify-content: space-between;
    align-items: center;
  }

  .bm-urgency-bar-sold {
    font-size: 12.5px;
    font-weight: 600;
    color: var(--bm-urgency-text-mid);
  }

  .bm-urgency-bar-remain {
    font-size: 12px;
    font-weight: 400;
    color: var(--bm-urgency-text-soft);
  }

  /* ============================================================
     CTA BUTTON
  ============================================================ */
  .bm-urgency-btn {
    display: block;
    width: 100%;
    padding: 15px 24px;
    background: var(--bm-urgency-btn-bg);
    color: #FFFFFF;
    font-family: var(--bm-urgency-font);
    font-size: 16px;
    font-weight: 700;
    text-align: center;
    text-decoration: none;
    border: none;
    border-radius: 10px;
    cursor: pointer;
    letter-spacing: 0.02em;
    line-height: 1.3;
    transition: background 0.2s ease, transform 0.15s ease, box-shadow 0.2s ease;
    box-shadow: 0 2px 8px rgba(139, 94, 60, 0.16);
  }

  .bm-urgency-btn:hover {
    background: var(--bm-urgency-btn-hover);
    transform: translateY(-1px);
    box-shadow: 0 6px 16px rgba(139, 94, 60, 0.22);
  }

  .bm-urgency-btn:active {
    transform: translateY(0);
    box-shadow: 0 2px 6px rgba(139, 94, 60, 0.14);
  }

  /* ============================================================
     RESPONSIVE
  ============================================================ */
  @media (max-width: 520px) {
    .bm-urgency-root  { padding: 14px; }
    .bm-urgency-card  { padding: 24px 18px; }
    .bm-urgency-headline { font-size: 17px; }
    .bm-urgency-btn   { font-size: 15px; padding: 14px 18px; }
  }
</style>

<div class="bm-urgency-root">
  <div class="bm-urgency-card" aria-label="מלאי מוגבל">

    <span class="bm-urgency-circle bm-urgency-circle--1" aria-hidden="true"></span>
    <span class="bm-urgency-circle bm-urgency-circle--2" aria-hidden="true"></span>
    <span class="bm-urgency-circle bm-urgency-circle--3" aria-hidden="true"></span>

    <div class="bm-urgency-content">

      <div class="bm-urgency-headline-row">
        <span class="bm-urgency-dot" aria-hidden="true"></span>
        <span class="bm-urgency-lightning" aria-hidden="true">⚡</span>
        <h2 class="bm-urgency-headline">{{ section.settings.headline }}</h2>
      </div>

      <div class="bm-urgency-bar-wrap">

        <div class="bm-urgency-stock-row">
          <span class="bm-urgency-stock-label">{{ section.settings.label_above_bar }}</span>
          <span class="bm-urgency-stock-count">{{ section.settings.stock_units }} {{ section.settings.label_remain }}</span>
        </div>

        <div
          class="bm-urgency-bar-track"
          role="progressbar"
          aria-valuemin="0"
          aria-valuemax="100"
          aria-label="פס מכירות"
        >
          <div class="bm-urgency-bar-fill"></div>
        </div>

        <div class="bm-urgency-bar-meta">
          <span class="bm-urgency-bar-sold">
            <span class="js-bm-urgency-pct">0</span>% {{ section.settings.label_sold }}
          </span>
          <span class="bm-urgency-bar-remain">{{ section.settings.stock_units }} {{ section.settings.label_remain }}</span>
        </div>

      </div>

      <a href="#product-form" class="bm-urgency-btn" aria-label="{{ section.settings.btn_text }}">
        {{ section.settings.btn_text }}
      </a>

    </div>
  </div>
</div>

<script>
  (function () {
    var card = document.querySelector('.bm-urgency-card');
    if (!card) return;

    /* ---- Determine target percentage ---- */
    var override   = {{ section.settings.sold_pct_override | default: 0 }};
    var targetPct  = (override > 0)
      ? override
      : (Math.floor(Math.random() * 13) + 82); /* random 82–94 */

    /* ---- Wire up bar fill target (CSS custom property) ---- */
    var fill  = card.querySelector('.bm-urgency-bar-fill');
    var track = card.querySelector('.bm-urgency-bar-track');
    var pctEl = card.querySelector('.js-bm-urgency-pct');

    if (fill)  fill.style.setProperty('--bm-urgency-bar-target', targetPct + '%');
    if (track) track.setAttribute('aria-valuenow', targetPct);

    /* ---- Counter animation ---- */
    function animateCounter(el, target) {
      var duration = 1200;
      var step     = 16;
      var steps    = Math.ceil(duration / step);
      var inc      = target / steps;
      var current  = 0;
      var timer    = setInterval(function () {
        current += inc;
        if (current >= target) { current = target; clearInterval(timer); }
        el.textContent = Math.round(current);
      }, step);
    }

    /* ---- Reveal (fade-up + bar + counter) ---- */
    var animated = false;
    function reveal() {
      if (animated) return;
      animated = true;
      card.classList.add('bm-urgency--visible');
      if (pctEl) animateCounter(pctEl, targetPct);
    }

    if (!('IntersectionObserver' in window)) { reveal(); return; }

    var observer = new IntersectionObserver(function (entries) {
      entries.forEach(function (entry) {
        if (entry.isIntersecting) { reveal(); observer.unobserve(entry.target); }
      });
    }, { threshold: 0.15 });

    observer.observe(card);
  })();
</script>

{% endif %}

{% schema %}
{
  "name": "BM — Store Urgency",
  "tag": "div",
  "class": "bm-store-urgency-section",
  "settings": [
    {
      "type": "checkbox",
      "id": "enabled",
      "label": "הצג בלוק מלאי",
      "default": true
    },
    {
      "type": "header",
      "content": "אחוזי מכירה"
    },
    {
      "type": "range",
      "id": "sold_pct_override",
      "label": "אחוז מכירה (0 = אוטומטי)",
      "min": 0,
      "max": 99,
      "step": 1,
      "default": 0,
      "info": "0 = אקראי בין 82–94% בכל טעינה. כל ערך אחר יוצג כקבוע."
    },
    {
      "type": "header",
      "content": "טקסטים"
    },
    {
      "type": "text",
      "id": "headline",
      "label": "כותרת",
      "default": "המלאי אוזל מהר"
    },
    {
      "type": "text",
      "id": "label_above_bar",
      "label": "טקסט מעל הפס",
      "default": "כבר נמכר ממלאי זה:"
    },
    {
      "type": "range",
      "id": "stock_units",
      "label": "מספר יחידות נותרו",
      "min": 1,
      "max": 50,
      "step": 1,
      "default": 8
    },
    {
      "type": "text",
      "id": "label_sold",
      "label": "תווית אחוזים (מתחת לפס, שמאל)",
      "default": "נמכר"
    },
    {
      "type": "text",
      "id": "label_remain",
      "label": "תווית יחידות (מתחת לפס, ימין)",
      "default": "יחידות נותרו"
    },
    {
      "type": "text",
      "id": "btn_text",
      "label": "טקסט כפתור",
      "default": "הוסיפו לעגלה"
    }
  ],
  "presets": [
    {
      "name": "BM — Store Urgency"
    }
  ]
}
{% endschema %}

    "bm_faq": {
      "type": "bm-store-faq",
      "blocks": {
        "faq_8f1aa691": {
          "type": "faq_item",
          "settings": {
            "question": "האם הסרבל מתאים לחורף?",
            "answer": "כן — הכותנה הסרוגה מספקת חמימות טבעית ומושלמת לסתיו ולחורף. לימות החורף הקרים במיוחד ניתן להוסיף שכבת בד פנימה."
          }
        },
        "faq_f570610e": {
          "type": "faq_item",
          "settings": {
            "question": "איך בוחרים מידה?",
            "answer": "מומלץ לבדוק את טבלת המידות בדף המוצר. לתינוקות גבוהים מגילם — כדאי לבחור מידה אחת מעלה. הסרבל מגיע במידות 0 עד 18 חודשים."
          }
        },
        "faq_4ff6eea3": {
          "type": "faq_item",
          "settings": {
            "question": "כמה זמן לוקח המשלוח?",
            "answer": "זמן האספקה הוא 5–10 ימי עסקים מרגע ביצוע ההזמנה. תקבלו מספר מעקב ב-SMS מיד לאחר שהחבילה יצאה לדרך."
          }
        },
        "faq_30b78600": {
          "type": "faq_item",
          "settings": {
            "question": "האם הסרבל מתאים כמתנה לידה?",
            "answer": "בהחלט! הסרבל הסרוג עם הפסים הצבעוניים הוא מתנת לידה מושלמת. ניתן להוסיף כרטיס ברכה אישי בהזמנה."
          }
        },
        "faq_40980d9b": {
          "type": "faq_item",
          "settings": {
            "question": "מה מדיניות ההחזרות?",
            "answer": "ניתן להחזיר מוצרים עד 14 יום מיום הקבלה, בתנאי שלא נעשה בהם שימוש. פנו אלינו ב-WhatsApp ונסייע בכל שאלה."
          }
        }
